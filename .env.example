# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/smart-syllabus-planner?retryWrites=true&w=majority

# JWT secret for session tokens (use a long random string in production)
JWT_SECRET=your-secret-key-min-32-chars

# Google Gemini API (used in later phases)
GEMINI_API_KEY=

# App URL (optional, for production callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000
